    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "# PROBE — determine a VALID pressure crossing label StyleId.\r\n# Uses ONE real pressure pvpart from your handoff. read-mostly; creates one label\r\n# WITHOUT a style arg if an overload allows, else inspects DefaultLabelStyle sources.\r\nimport clr\r\nclr.AddReference('AeccDbMgd'); clr.AddReference('AcDbMgd'); clr.AddReference('AcMgd')\r\nfrom Autodesk.AutoCAD.ApplicationServices import Application\r\nfrom Autodesk.AutoCAD.DatabaseServices import OpenMode, Handle, ObjectId\r\nfrom Autodesk.Civil.ApplicationServices import CivilApplication\r\nimport Autodesk.Civil.DatabaseServices as cds\r\nfrom Autodesk.AutoCAD.Runtime import RXClass\r\n\r\nadoc = Application.DocumentManager.MdiActiveDocument\r\ndb = adoc.Database\r\ncivdoc = CivilApplication.ActiveDocument\r\nout = {}\r\n\r\n# 1) List Create overloads for CrossingPressurePipeProfileLabel — is there a\r\n#    signature WITHOUT a style id?\r\ntry:\r\n    m = cds.CrossingPressurePipeProfileLabel.Create\r\n    out[\"Create_overloads\"] = str(m.Overloads)\r\nexcept Exception as e:\r\n    out[\"Create_overloads\"] = f\"ERR {e}\"\r\n\r\n# 2) Is there any existing PressurePartProfileLabel / crossing label in the drawing\r\n#    whose StyleId we can borrow? Scan ModelSpace for that RXClass.\r\nfrom Autodesk.AutoCAD.DatabaseServices import BlockTableRecord, SymbolUtilityServices\r\nfound_style = None\r\nwith adoc.LockDocument():\r\n    with db.TransactionManager.StartTransaction() as tr:\r\n        ms = tr.GetObject(SymbolUtilityServices.GetBlockModelSpaceId(db), OpenMode.ForRead)\r\n        target = None\r\n        for cand in (\"CrossingPressurePipeProfileLabel\", \"PressurePartProfileLabel\"):\r\n            try:\r\n                target = RXClass.GetClass(getattr(cds, cand)); break\r\n            except Exception:\r\n                continue\r\n        cnt = 0\r\n        for oid in ms:\r\n            try:\r\n                if oid.ObjectClass.IsDerivedFrom(target):\r\n                    lab = tr.GetObject(oid, OpenMode.ForRead)\r\n                    found_style = (lab.StyleName, str(lab.StyleId), lab.StyleId.IsNull)\r\n                    cnt += 1\r\n                    if cnt >= 1: break\r\n            except Exception:\r\n                pass\r\n        out[\"existing_label_count\"] = cnt\r\n        out[\"borrowed_style\"] = found_style\r\n\r\n# 3) What does PipeLabelStyles.CrossProfileLabelStyles.DefaultLabelStyle give,\r\n#    and is it the SAME thing that failed? (sanity)\r\ntry:\r\n    d = civdoc.Styles.LabelStyles.PipeLabelStyles.CrossProfileLabelStyles.DefaultLabelStyle\r\n    out[\"gravity_default_style\"] = (str(d), d.IsNull)\r\nexcept Exception as e:\r\n    out[\"gravity_default_style\"] = f\"ERR {e}\"\r\n\r\nOUT = out\r\n",
      "Engine": "CPython3",
      "VariableInputPorts": true,
      "Id": "89ffe0ec66b94c7eb5c28fabd5d7d5af",
      "NodeType": "PythonScriptNode",
      "Inputs": [
        {
          "Id": "429be9d9d2e546318bcef79ead707317",
          "Name": "IN[0]",
          "Description": "Input #0",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Outputs": [
