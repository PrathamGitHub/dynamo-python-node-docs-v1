    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "# Open the pressure style's OwnerId -> is it a style collection? enumerate it. Compare to gravity coll. ABORT.\r\nimport clr\r\ntry: clr.AddReference(\"AeccPressurePipesMgd\")\r\nexcept Exception: pass\r\nfrom Autodesk.AutoCAD.ApplicationServices import Application\r\nfrom Autodesk.AutoCAD.DatabaseServices import OpenMode, SymbolUtilityServices\r\nfrom Autodesk.Civil.ApplicationServices import CivilDocument\r\nimport Autodesk.Civil.DatabaseServices as cds\r\nfrom Autodesk.AutoCAD.Runtime import RXClass\r\n\r\ndef style_name(o):\r\n    return o.GetType().GetMethod(\"get_Name\").Invoke(o, None)\r\n\r\nlog = []\r\nadoc = Application.DocumentManager.MdiActiveDocument\r\ndb = adoc.Database\r\ncivdoc = CivilDocument.GetCivilDocument(db)\r\nlock = adoc.LockDocument()\r\ntr = db.TransactionManager.StartTransaction()\r\ntry:\r\n    target = None\r\n    for cand in (\"CrossingPressurePipeProfileLabel\", \"PressurePartProfileLabel\"):\r\n        try: target = RXClass.GetClass(getattr(cds, cand)); break\r\n        except Exception: pass\r\n    ms = tr.GetObject(SymbolUtilityServices.GetBlockModelSpaceId(db), OpenMode.ForRead)\r\n    owner_id = None; placed_names = set()\r\n    if target:\r\n        for oid in ms:\r\n            try:\r\n                if oid.ObjectClass.IsDerivedFrom(target):\r\n                    lab = tr.GetObject(oid, OpenMode.ForRead)\r\n                    sid = getattr(lab, \"StyleId\", None)\r\n                    if sid is not None and not sid.IsNull:\r\n                        st = tr.GetObject(sid, OpenMode.ForRead)\r\n                        placed_names.add(style_name(st))\r\n                        if owner_id is None:\r\n                            owner_id = st.OwnerId\r\n            except Exception: pass\r\n    log.append(f\"placed pressure style names: {sorted(placed_names)}\")\r\n\r\n    if owner_id is not None and not owner_id.IsNull:\r\n        owner = tr.GetObject(owner_id, OpenMode.ForRead)\r\n        log.append(f\"OwnerId -> type {owner.GetType().FullName}\")\r\n        # try to enumerate it as a style collection\r\n        try:\r\n            ids = list(owner.ToObjectIds())\r\n            names = [style_name(tr.GetObject(i, OpenMode.ForRead)) for i in ids]\r\n            log.append(f\"OwnerId collection ({len(names)}): {names}\")\r\n        except Exception as e:\r\n            log.append(f\"OwnerId.ToObjectIds ERR: {e}\")\r\n\r\n    # gravity collection for comparison\r\n    gcoll = civdoc.Styles.LabelStyles.PipeLabelStyles.CrossProfileLabelStyles\r\n    gids = list(gcoll.ToObjectIds())\r\n    log.append(f\"gravity CrossProfileLabelStyles ({len(gids)}): \"\r\n               f\"{[style_name(tr.GetObject(i, OpenMode.ForRead)) for i in gids]}\")\r\n    log.append(f\"OwnerId == gravity-coll ObjectId? {owner_id == gcoll.ObjectId if owner_id else 'n/a'}\")\r\n    tr.Abort()\r\nexcept Exception as e:\r\n    log.append(f\"EXC {type(e).__name__}: {e}\"); tr.Abort()\r\nfinally:\r\n    tr.Dispose(); lock.Dispose()\r\n\r\nOUT = log",
      "Engine": "CPython3",
      "VariableInputPorts": true,
      "Id": "a04e8768c8414c38acdb150d202a2ebd",
      "NodeType": "PythonScriptNode",
      "Inputs": [
        {
          "Id": "e17e927081794288b7b620d8da4834c6",
          "Name": "IN[0]",
          "Description": "Input #0",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "e6bfa4ee34b14f67a1046edf11bb2b6f",
          "Name": "IN[1]",
          "Description": "Input #1",
          "UsingDefaultValue": false,
