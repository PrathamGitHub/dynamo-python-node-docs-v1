    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "# Node A: Export description->style mapping templates + available-style pick-lists.\r\n# IN[0] = duckdb_path, IN[1] = output directory for the CSVs.\r\nimport csv, os, clr\r\ntry:\r\n    clr.AddReference(\"AeccPressurePipesMgd\")\r\nexcept Exception:\r\n    pass\r\nfrom Autodesk.AutoCAD.ApplicationServices import Application\r\nfrom Autodesk.AutoCAD.DatabaseServices import OpenMode, SymbolUtilityServices\r\nfrom Autodesk.Civil.ApplicationServices import CivilDocument\r\nimport Autodesk.Civil.DatabaseServices as cds\r\nfrom Autodesk.AutoCAD.Runtime import RXClass\r\nfrom automations import duckdb_engine as duck\r\n\r\nduckdb_path = IN[0]\r\nout_dir     = IN[1]\r\n\r\ndef style_name(o):\r\n    \"\"\"Read a style Name via CLR get_Name reflection (pythonnet .Name throws on this build).\"\"\"\r\n    return o.GetType().GetMethod(\"get_Name\").Invoke(o, None)\r\n\r\ndef write_csv(path, header, rows):\r\n    with open(path, \"w\", newline=\"\", encoding=\"utf-8-sig\") as f:  # utf-8-sig => Excel + unicode (∅) safe\r\n        w = csv.writer(f)\r\n        w.writerow(header)\r\n        for r in rows:\r\n            w.writerow(r)\r\n\r\nlog = []\r\nadoc = Application.DocumentManager.MdiActiveDocument\r\ndb = adoc.Database\r\ncivdoc = CivilDocument.GetCivilDocument(db)\r\ncon = duck.connect(duckdb_path)\r\nlock = adoc.LockDocument()\r\ntr = db.TransactionManager.StartTransaction()\r\ntry:\r\n    # 1 & 2: distinct descriptions per role (NULL -> '' so the blank bucket is one row)\r\n    for role, fname in ((\"gravity_cross\", \"gravity_label_map.csv\"),\r\n                        (\"pressure_cross\", \"pressure_label_map.csv\")):\r\n        descs = con.execute(f\"\"\"SELECT DISTINCT COALESCE(description,'') AS d, COUNT(*) n\r\n                                FROM pipes WHERE role=? GROUP BY 1 ORDER BY n DESC\"\"\",\r\n                            [role]).fetchall()\r\n        write_csv(os.path.join(out_dir, fname),\r\n                  [\"description\", \"label_style_name\"],\r\n                  [[d, \"\"] for d, _n in descs])\r\n        log.append(f\"{fname}: {len(descs)} descriptions\")\r\n\r\n    # 3: gravity available styles (collection + get_Name reflection)\r\n    coll = civdoc.Styles.LabelStyles.PipeLabelStyles.CrossProfileLabelStyles\r\n    gnames = [style_name(tr.GetObject(sid, OpenMode.ForRead)) for sid in coll.ToObjectIds()]\r\n    write_csv(os.path.join(out_dir, \"gravity_label_styles.csv\"),\r\n              [\"available_gravity_label_style\"], [[n] for n in gnames])\r\n    log.append(f\"gravity_label_styles.csv: {len(gnames)} styles\")\r\n\r\n    # 4: pressure available styles (BORROWABLE placed-label StyleNames only)\r\n    target = None\r\n    for cand in (\"CrossingPressurePipeProfileLabel\", \"PressurePartProfileLabel\"):\r\n        try:\r\n            target = RXClass.GetClass(getattr(cds, cand)); break\r\n        except Exception:\r\n            continue\r\n    ms = tr.GetObject(SymbolUtilityServices.GetBlockModelSpaceId(db), OpenMode.ForRead)\r\n    pnames = set()\r\n    if target:\r\n        for oid in ms:\r\n            try:\r\n                if oid.ObjectClass.IsDerivedFrom(target):\r\n                    lab = tr.GetObject(oid, OpenMode.ForRead)\r\n                    sn = getattr(lab, \"StyleName\", None)   # readable on placed labels (Probe 2)\r\n                    if sn:\r\n                        pnames.add(sn)\r\n            except Exception:\r\n                continue\r\n    write_csv(os.path.join(out_dir, \"pressure_label_styles.csv\"),\r\n              [\"available_pressure_label_style (must be PLACED to be usable)\"],\r\n              [[n] for n in sorted(pnames)])\r\n    log.append(f\"pressure_label_styles.csv: {len(pnames)} borrowable styles \"\r\n               f\"({'none placed yet' if not pnames else ''})\")\r\n\r\n    tr.Abort()\r\nexcept Exception as e:\r\n    log.append(f\"EXC: {type(e).__name__}: {e}\")\r\n    tr.Abort()\r\nfinally:\r\n    tr.Dispose(); lock.Dispose()\r\n\r\nOUT = log\r\n",
      "Engine": "CPython3",
      "VariableInputPorts": true,
      "Id": "e3b16407a9cb47e89865f2666a19a67b",
      "NodeType": "PythonScriptNode",
      "Inputs": [
        {
          "Id": "05ed71515d21434abd87a41d95b560c5",
          "Name": "IN[0]",
          "Description": "Input #0",
          "UsingDefaultValue": false,
