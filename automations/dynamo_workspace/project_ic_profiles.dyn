    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "# Stage 8b: Re-fix profile view band items after Stage 8 has committed & datum settled.\r\n# IN[0] = list of PV handles (strings) OR ObjectIds output by Stage 8.\r\nimport clr\r\nfrom Autodesk.AutoCAD.ApplicationServices import Application\r\nfrom Autodesk.AutoCAD.DatabaseServices import OpenMode, Handle\r\nfrom Autodesk.Civil.ApplicationServices import CivilDocument\r\n\r\npv_handles = IN[0]   # e.g. [\"1184FC\", ...] — adapt to whatever Stage 8 actually returns\r\n\r\nlog = []\r\nif IN[1]:\r\n    adoc = Application.DocumentManager.MdiActiveDocument\r\n    adoc.Editor.Regen()   # settle datum from Stage 8's committed parts before band round-trip\r\n    db = adoc.Database\r\n    lock = adoc.LockDocument()\r\n    tr = db.TransactionManager.StartTransaction()\r\n    try:\r\n        fixed = 0\r\n        for h in pv_handles:\r\n            try:\r\n                oid = db.GetObjectId(False, Handle(int(h, 16)), 0)\r\n                pv = tr.GetObject(oid, OpenMode.ForWrite)\r\n            except Exception as ex:\r\n                log.append(\"skip {}: {}\".format(h, ex))\r\n                continue\r\n            try:\r\n                bottom = pv.Bands.GetBottomBandItems()\r\n                pv.Bands.SetBottomBandItems(bottom)\r\n                top = pv.Bands.GetTopBandItems()\r\n                pv.Bands.SetTopBandItems(top)\r\n                fixed += 1\r\n            except Exception as ex:\r\n                log.append(\"band fix failed for {}: {}\".format(h, ex))\r\n        tr.Commit()\r\n        log.append(\"fixed {} of {} PVs\".format(fixed, len(pv_handles)))\r\n    except Exception as e:\r\n        log.append(\"EXC: {}: {}\".format(type(e).__name__, e))\r\n        tr.Abort()\r\n    finally:\r\n        tr.Dispose()\r\n        lock.Dispose()\r\n\r\nOUT = log\r\n",
      "Engine": "CPython3",
      "VariableInputPorts": true,
      "Id": "f0d25ffaba8146dc8abc934d3f434a67",
      "NodeType": "PythonScriptNode",
      "Inputs": [
        {
          "Id": "3cabd8e886b94c0893599e864a1298f7",
          "Name": "IN[0]",
          "Description": "Input #0",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "46f756f68f764c9292a4026f42146f23",
          "Name": "IN[1]",
          "Description": "Input #1",
          "UsingDefaultValue": false,
