    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "# Probe: inspect ProfileViewPart / label-like entities around PIPE-10 PVs.\r\n# No IN required.\r\n\r\nimport traceback\r\nimport clr\r\n\r\nfrom Autodesk.AutoCAD.ApplicationServices import Application\r\nfrom Autodesk.AutoCAD.DatabaseServices import OpenMode, SymbolUtilityServices\r\nfrom Autodesk.Civil.ApplicationServices import CivilDocument\r\n\r\nadoc = Application.DocumentManager.MdiActiveDocument\r\ndb = adoc.Database\r\ncivdoc = CivilDocument.GetCivilDocument(db)\r\n\r\ndef oid_s(oid):\r\n    try:\r\n        if oid is None or oid.IsNull:\r\n            return \"Null\"\r\n        return oid.Handle.ToString()\r\n    except Exception:\r\n        return str(oid)\r\n\r\ndef safe(obj, attr):\r\n    try:\r\n        if hasattr(obj, attr):\r\n            v = getattr(obj, attr)\r\n            if hasattr(v, \"X\") and hasattr(v, \"Y\"):\r\n                return (round(v.X, 3), round(v.Y, 3), round(getattr(v, \"Z\", 0.0), 3))\r\n            if hasattr(v, \"Handle\"):\r\n                return oid_s(v)\r\n            return str(v)\r\n    except Exception as e:\r\n        return f\"ERR:{type(e).__name__}:{e}\"\r\n    return None\r\n\r\ndef obj_name(tr, oid):\r\n    try:\r\n        if oid is None or oid.IsNull:\r\n            return None\r\n        o = tr.GetObject(oid, OpenMode.ForRead)\r\n        return getattr(o, \"Name\", None)\r\n    except Exception:\r\n        return None\r\n\r\nrep = {\"profile_views\": [], \"pvparts\": [], \"labels\": [], \"errors\": []}\r\n\r\nwith adoc.LockDocument():\r\n    with db.TransactionManager.StartTransaction() as tr:\r\n        try:\r\n            # 1) List relevant profile views.\r\n            pvid_by_handle = {}\r\n            for aid in civdoc.GetAlignmentIds():\r\n                aln = tr.GetObject(aid, OpenMode.ForRead)\r\n                try:\r\n                    pv_ids = list(aln.GetProfileViewIds())\r\n                except Exception:\r\n                    pv_ids = []\r\n                for pvid in pv_ids:\r\n                    pv = tr.GetObject(pvid, OpenMode.ForRead)\r\n                    if \"PIPE-10\" in pv.Name or \"PIPE-10\" in aln.Name:\r\n                        h = oid_s(pvid)\r\n                        pvid_by_handle[h] = pvid\r\n                        rep[\"profile_views\"].append({\r\n                            \"alignment\": aln.Name,\r\n                            \"pv\": pv.Name,\r\n                            \"pv_handle\": h,\r\n                            \"location\": safe(pv, \"Location\"),\r\n                            \"elev_min\": safe(pv, \"ElevationMin\"),\r\n                            \"elev_max\": safe(pv, \"ElevationMax\"),\r\n                        })\r\n\r\n            # 2) Scan ModelSpace for PV parts and label-like objects.\r\n            ms_id = SymbolUtilityServices.GetBlockModelSpaceId(db)\r\n            ms = tr.GetObject(ms_id, OpenMode.ForRead)\r\n\r\n            for eid in ms:\r\n                try:\r\n                    ent = tr.GetObject(eid, OpenMode.ForRead)\r\n                    typ = ent.GetType().Name\r\n                    typ_full = ent.GetType().FullName\r\n\r\n                    is_pvpart = \"ProfileViewPart\" in typ or \"ProfileViewPressurePart\" in typ\r\n                    is_label = \"Label\" in typ\r\n\r\n                    if not (is_pvpart or is_label):\r\n                        continue\r\n\r\n                    row = {\r\n                        \"handle\": oid_s(eid),\r\n                        \"type\": typ,\r\n                        \"full\": typ_full,\r\n                        \"location\": safe(ent, \"Location\"),\r\n                        \"label_location\": safe(ent, \"LabelLocation\"),\r\n                        \"position\": safe(ent, \"Position\"),\r\n                        \"profile_view_id\": safe(ent, \"ProfileViewId\"),\r\n                        \"model_part_id\": safe(ent, \"ModelPartId\"),\r\n                        \"part_id\": safe(ent, \"PartId\"),\r\n                        \"style_id\": safe(ent, \"StyleId\"),\r\n                        \"style_name\": safe(ent, \"StyleName\"),\r\n                    }\r\n\r\n                    # If it references a PV, add PV name.\r\n                    for key in (\"ProfileViewId\",):\r\n                        try:\r\n                            if hasattr(ent, key):\r\n                                pvid = getattr(ent, key)\r\n                                row[\"profile_view_name\"] = obj_name(tr, pvid)\r\n                        except Exception:\r\n                            pass\r\n\r\n                    # Only keep all PV parts, but restrict labels a bit if possible.\r\n                    if is_pvpart:\r\n                        rep[\"pvparts\"].append(row)\r\n                    elif is_label:\r\n                        # Keep label rows if they reference a PIPE-10 PV, or if location is suspiciously near/under profile area.\r\n                        pvname = row.get(\"profile_view_name\") or \"\"\r\n                        if \"PIPE-10\" in pvname or len(rep[\"labels\"]) < 80:\r\n                            rep[\"labels\"].append(row)\r\n\r\n                except Exception as e:\r\n                    rep[\"errors\"].append(f\"{oid_s(eid)}: {type(e).__name__}: {e}\")\r\n\r\n            tr.Abort()\r\n        except Exception as e:\r\n            rep[\"fatal\"] = f\"{type(e).__name__}: {e}\"\r\n            rep[\"trace\"] = traceback.format_exc()\r\n            tr.Abort()\r\n\r\nOUT = rep\r\n",
      "Engine": "CPython3",
      "VariableInputPorts": true,
      "Id": "e609dc1f1b164611a28af71cbd6e9f77",
      "NodeType": "PythonScriptNode",
      "Inputs": [
        {
          "Id": "8c5a8dced5654b0f9cc572ac2e19bd62",
          "Name": "IN[0]",
          "Description": "Input #0",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Outputs": [
        {
          "Id": "5085f195a54c4842a1a7819fae0a3c71",
          "Name": "OUT",
          "Description": "Result of the python script",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Replication": "Disabled",
      "Description": "Runs an embedded Python script."
    },
